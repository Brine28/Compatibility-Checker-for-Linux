<?xml version="1.0" encoding="utf-8"?>
<!--
  lcc_driver.vcxproj
  Visual Studio 2022 + WDK 10 kernel-mode driver project.
  ─────────────────────────────────────────────────────────
  Requirements:
    • Visual Studio 2022 (any edition)
    • Windows Driver Kit (WDK) for Windows 11
    • Spectre-mitigated libraries (optional but recommended)

  Build steps:
    1. Open this .vcxproj in VS2022 (or msbuild from Developer CMD)
    2. Set Configuration = "Release", Platform = "x64"
    3. Build → lcc_driver.sys is in x64\Release\

  Test-signing (development only):
    bcdedit /set testsigning on   [reboot]
    signtool sign /v /s PrivateCertStore /n "TestCert" lcc_driver.sys
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <TargetFrameworkVersion>v4.5</TargetFrameworkVersion>
    <MinimumVisualStudioVersion>17.0</MinimumVisualStudioVersion>
    <Configuration Condition="'$(Configuration)'==''">Release</Configuration>
    <Platform       Condition="'$(Platform)'==''">x64</Platform>
    <RootNamespace>lcc_driver</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <WindowsTargetPlatformMinVersion>10.0.19041.0</WindowsTargetPlatformMinVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <!-- WDK 10.0.28000.0 paths — hard-coded for VS 2026 compatibility -->
  <PropertyGroup>
    <WDKVersion>10.0.28000.0</WDKVersion>
    <WDKRoot>C:\Program Files (x86)\Windows Kits\10</WDKRoot>
    <WDKIncludes>$(WDKRoot)\Include\$(WDKVersion)\km;$(WDKRoot)\Include\$(WDKVersion)\shared;$(WDKRoot)\Include\$(WDKVersion)\um;$(WDKRoot)\Include\wdf\kmdf\1.35</WDKIncludes>
    <WDKLibs>$(WDKRoot)\Lib\$(WDKVersion)\km\x64</WDKLibs>
    <WDFLibs>$(WDKRoot)\Lib\wdf\kmdf\x64\1.35</WDFLibs>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <PlatformToolset>v145</PlatformToolset>
    <UseDebugLibraries>false</UseDebugLibraries>
    <CharacterSet>Unicode</CharacterSet>
    <SpectreMitigation>Spectre</SpectreMitigation>
    <TargetExt>.sys</TargetExt>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <PlatformToolset>v145</PlatformToolset>
    <UseDebugLibraries>true</UseDebugLibraries>
    <CharacterSet>Unicode</CharacterSet>
    <TargetExt>.sys</TargetExt>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />

  <ImportGroup Label="ExtensionSettings" />
  <ImportGroup Label="Shared" />

  <!-- Kernel drivers cannot have manifests — disable globally -->
  <PropertyGroup>
    <GenerateManifest>false</GenerateManifest>
    <EmbedManifest>false</EmbedManifest>
  </PropertyGroup>

  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props"
            Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')"
            Label="LocalAppDataPlatforms" />
  </ImportGroup>

  <PropertyGroup Label="UserMacros" />

  <!-- ── Compiler / Linker settings ────────────────────────────── -->
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <AdditionalIncludeDirectories>$(WDKIncludes);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>NDEBUG;_WIN64;_AMD64_;_KERNEL_MODE;KMDF_VERSION_MAJOR=1;KMDF_VERSION_MINOR=35;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <WarnAsError>false</WarnAsError>
      <WarningLevel>Level4</WarningLevel>
      <Optimization>MaxSpeed</Optimization>
      <FavorSizeOrSpeed>Speed</FavorSizeOrSpeed>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <BufferSecurityCheck>false</BufferSecurityCheck>
      <BasicRuntimeChecks>Default</BasicRuntimeChecks>
    </ClCompile>
    <Link>
      <AdditionalDependencies>ntoskrnl.lib;hal.lib;wdm.lib;$(WDFLibs)\WdfLdr.lib</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(WDKLibs);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <EntryPointSymbol>DriverEntry</EntryPointSymbol>
      <SubSystem>Native</SubSystem>
      <Driver>WDM</Driver>
      <NoDefaultLib>true</NoDefaultLib>
      <ImageHasSafeExceptionHandlers>false</ImageHasSafeExceptionHandlers>
      <GenerateManifest>false</GenerateManifest>
      <OutputFile>$(OutDir)lcc_driver.sys</OutputFile>
      <AdditionalOptions>/DRIVER:WDM /NODEFAULTLIB %(AdditionalOptions)</AdditionalOptions>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <AdditionalIncludeDirectories>$(WDKIncludes);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <PreprocessorDefinitions>DBG=1;_WIN64;_AMD64_;_KERNEL_MODE;KMDF_VERSION_MAJOR=1;KMDF_VERSION_MINOR=35;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <WarnAsError>false</WarnAsError>
      <WarningLevel>Level4</WarningLevel>
      <Optimization>Disabled</Optimization>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <BufferSecurityCheck>false</BufferSecurityCheck>
      <BasicRuntimeChecks>Default</BasicRuntimeChecks>
    </ClCompile>
    <Link>
      <AdditionalDependencies>ntoskrnl.lib;hal.lib;wdm.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <AdditionalLibraryDirectories>$(WDKLibs);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <EntryPointSymbol>DriverEntry</EntryPointSymbol>
      <SubSystem>Native</SubSystem>
      <Driver>WDM</Driver>
      <NoDefaultLib>true</NoDefaultLib>
      <ImageHasSafeExceptionHandlers>false</ImageHasSafeExceptionHandlers>
      <GenerateManifest>false</GenerateManifest>
    </Link>
  </ItemDefinitionGroup>

  <!-- ── Source files ──────────────────────────────────────────── -->
  <ItemGroup>
    <ClCompile Include="lcc_driver_wdm.c" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="lcc_shared.h" />
  </ItemGroup>

  <ItemGroup>
    <Inf Include="lcc_driver.inf" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />

</Project>
